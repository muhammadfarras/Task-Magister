mask = dirty_data['Price Per Unit'].isnull()
dirty_data.loc[mask,'Price Per Unit'] = (dirty_data.loc[mask,'Total Spent'] / dirty_data.loc[mask,'Quantity'])


dirty_data.info()





dirty_data['Price Per Unit'].unique()





